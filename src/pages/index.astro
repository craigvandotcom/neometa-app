---
import Base from '../layouts/Base.astro'

const pillars = [
  {
    name: 'Eat',
    description: 'What your food does.',
    apps: ['Body Compass'],
    colorClass: 'bg-eat-500',
    bgClass: 'bg-eat-50',
    borderClass: 'border-eat-200',
  },
  {
    name: 'Move',
    description: 'What your body does.',
    apps: ['Unsit', 'Move Free'],
    colorClass: 'bg-move-500',
    bgClass: 'bg-move-50',
    borderClass: 'border-move-200',
  },
  {
    name: 'Meditate',
    description: 'What your nervous system does.',
    apps: ['Art Still'],
    colorClass: 'bg-meditate-500',
    bgClass: 'bg-meditate-50',
    borderClass: 'border-meditate-200',
  },
]

const apps = [
  {
    name: 'Body Compass',
    domain: 'bodycompass.app',
    pillar: 'Eat',
    accent: 'text-eat-700',
    dot: 'bg-eat-500',
    description:
      'Health tracking with AI-powered food analysis. Patterns, not calories.',
    status: 'Production',
    href: 'https://bodycompass.app',
  },
  {
    name: 'Unsit',
    domain: 'unsit.app',
    pillar: 'Move',
    accent: 'text-move-700',
    dot: 'bg-move-500',
    description:
      '12-week structured program for desk-bound back recovery. Corrective, not performative.',
    status: 'Beta',
    href: 'https://unsit.app',
  },
  {
    name: 'Move Free',
    domain: 'movefreedom.app',
    pillar: 'Move',
    accent: 'text-move-700',
    dot: 'bg-move-500',
    description:
      'Mobility training across the major joint systems. Capable, earned, clinically grounded.',
    status: 'In development',
    href: null,
  },
  {
    name: 'Art Still',
    domain: 'artstill.app',
    pillar: 'Meditate',
    accent: 'text-meditate-700',
    dot: 'bg-meditate-500',
    description:
      'Real-time biofeedback meditation. Camera-based stillness sensing with reactive audio.',
    status: 'In development',
    href: null,
  },
]
---

<Base>
  <!-- Header -->
  <header class="border-b border-border-light/60">
    <div class="max-w-default mx-auto px-6 py-6 flex items-center justify-between">
      <a href="/" class="font-display text-2xl tracking-tight text-ink">
        neoMeta
      </a>
      <nav class="text-sm text-ink-muted">
        <a href="#apps" class="hover:text-ink transition-colors duration-base">Apps</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="max-w-default mx-auto px-6 pt-32 pb-40 md:pt-40 md:pb-48">
    <div class="max-w-3xl">
      <p class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-8">
        Health sovereignty
      </p>
      <h1 class="font-display text-5xl md:text-7xl leading-[1.05] text-ink mb-10">
        Your body produces signal.<br />
        <span class="text-ink-muted">Our tools make it legible.</span>
      </h1>
      <p class="text-lg md:text-xl text-ink-muted leading-relaxed max-w-2xl">
        neoMeta is a portfolio of four apps for understanding your own biology — across what
        you eat, how you move, and how you rest. One compass system. Four orientation tools.
      </p>
    </div>
  </section>

  <!-- The three pillars -->
  <section class="max-w-default mx-auto px-6 py-24 border-t border-border-light/60">
    <div class="max-w-2xl mb-16">
      <p class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-6">
        The three pillars
      </p>
      <h2 class="font-display text-4xl md:text-5xl leading-tight text-ink">
        Eat. Move. Meditate.
      </h2>
      <p class="text-lg text-ink-muted leading-relaxed mt-6">
        Three integrated practices for understanding the system you already are.
        Each pillar is a domain of signal — and an app that helps you read it.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        pillars.map((p) => (
          <div class={`rounded-xl p-8 ${p.bgClass} border ${p.borderClass}`}>
            <div class="flex items-center gap-3 mb-6">
              <span class={`w-3 h-3 rounded-full ${p.colorClass}`}></span>
              <h3 class="font-display text-2xl text-ink">{p.name}</h3>
            </div>
            <p class="text-base text-ink leading-relaxed mb-6">{p.description}</p>
            <ul class="space-y-1">
              {p.apps.map((app) => (
                <li class="text-sm text-ink-muted">{app}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- The four apps -->
  <section id="apps" class="max-w-default mx-auto px-6 py-24 border-t border-border-light/60">
    <div class="max-w-2xl mb-16">
      <p class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-6">
        The portfolio
      </p>
      <h2 class="font-display text-4xl md:text-5xl leading-tight text-ink">
        Four compasses. One body.
      </h2>
      <p class="text-lg text-ink-muted leading-relaxed mt-6">
        Each app is a tool for one domain of signal. Used together, they form
        an integrated practice of health sovereignty.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border-light/60 border border-border-light/60 rounded-xl overflow-hidden">
      {
        apps.map((app) => (
          <article class="bg-surface-warm p-8 flex flex-col">
            <div class="flex items-baseline gap-3 mb-2">
              <span class={`w-2 h-2 rounded-full ${app.dot}`}></span>
              <span class={`text-xs font-medium uppercase tracking-wider ${app.accent}`}>
                {app.pillar}
              </span>
            </div>
            <h3 class="font-display text-3xl text-ink mb-3">{app.name}</h3>
            <p class="text-base text-ink-muted leading-relaxed mb-6 flex-1">
              {app.description}
            </p>
            <div class="flex items-center justify-between text-sm pt-6 border-t border-border-light/60">
              <span class="text-ink-muted">{app.status}</span>
              {app.href ? (
                <a
                  href={app.href}
                  class="text-ink hover:text-ink-muted transition-colors duration-base"
                >
                  {app.domain} →
                </a>
              ) : (
                <span class="text-ink-muted">{app.domain}</span>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Founder's note -->
  <section class="max-w-default mx-auto px-6 py-24 border-t border-border-light/60">
    <div class="max-w-2xl">
      <p class="text-sm font-medium text-ink-muted uppercase tracking-wider mb-6">
        On who's building this
      </p>
      <h2 class="font-display text-3xl md:text-4xl leading-tight text-ink mb-8">
        Built by one engineer with a swarm of AI agents.
      </h2>
      <div class="space-y-6 text-lg text-ink-muted leading-relaxed">
        <p>
          neoMeta is the work of Craig van Heerden — biokineticist (BSc Hons,
          University of the Witwatersrand), data scientist (MSc, Tilburg),
          and agentic engineer.
        </p>
        <p>
          The thesis: health is too personal for generic protocols, too systemic
          for single-app solutions, and too important to leave to the wellness
          industry's current conventions. Four apps, one operating philosophy,
          and a system designed for n=1 — your body, not the average body.
        </p>
        <p class="text-base">
          <a
            href="https://github.com/craigvandotcom"
            class="text-ink underline underline-offset-4 decoration-border-light hover:decoration-ink transition-colors duration-base"
          >
            github.com/craigvandotcom
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="max-w-default mx-auto px-6 py-16 border-t border-border-light/60">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <p class="font-display text-xl text-ink">neoMeta</p>
        <p class="text-sm text-ink-muted mt-2">
          Health sovereignty across food, movement, and stillness.
        </p>
      </div>
      <div class="flex gap-6 text-sm text-ink-muted">
        <a href="https://bodycompass.app" class="hover:text-ink transition-colors duration-base">
          bodycompass.app
        </a>
        <a href="https://unsit.app" class="hover:text-ink transition-colors duration-base">
          unsit.app
        </a>
        <span>movefreedom.app</span>
        <span>artstill.app</span>
      </div>
    </div>
    <p class="text-xs text-ink-muted/70 mt-12">
      © 2026 Craig van Heerden
    </p>
  </footer>
</Base>
